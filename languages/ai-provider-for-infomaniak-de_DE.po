#. Plugin Name of the plugin
#: plugin.php
msgid "AI Provider for Infomaniak"
msgstr "KI-Anbieter für Infomaniak"

#. Plugin URI of the plugin
#: plugin.php
msgid "https://www.infomaniak.com/en/hosting/ai-tools"
msgstr "https://www.infomaniak.com/de/hosting/ai-tools"

#. Description of the plugin
#: plugin.php
msgid ""
"AI Provider for Infomaniak for the WordPress AI Client. Provides access to "
"open-source models (Llama, Mistral, DeepSeek, Qwen) hosted in Switzerland."
msgstr ""
"KI-Anbieter für Infomaniak für den WordPress-KI-Client. Bietet Zugang zu "
"Open-Source-Modellen (Llama, Mistral, DeepSeek, Qwen), die in der Schweiz "
"gehostet werden."

#. Author of the plugin
#: plugin.php
msgid "Custom"
msgstr "Custom"

#: plugin.php:120
msgid "Infomaniak AI Configuration"
msgstr "Infomaniak AI Konfiguration"

#: plugin.php:123
msgid ""
"Configure your Infomaniak AI product settings. Your API token is managed via "
"Settings > Connectors."
msgstr ""
"Konfigurieren Sie Ihre Infomaniak AI Produkteinstellungen. Ihr API-Token "
"wird unter Einstellungen > Konnektoren verwaltet."

#: plugin.php:134
msgid "Product ID"
msgstr "Produkt-ID"

#: plugin.php:144
msgid "Currently set via the INFOMANIAK_AI_PRODUCT_ID constant."
msgstr "Derzeit über die Konstante INFOMANIAK_AI_PRODUCT_ID festgelegt."

#: plugin.php:149
msgid "Currently set via the infomaniak_ai_product_id filter."
msgstr "Derzeit über den Filter infomaniak_ai_product_id festgelegt."

#: plugin.php:154
msgid ""
"Your Infomaniak AI product ID. Find it in your Infomaniak manager at AI "
"Tools."
msgstr ""
"Ihre Infomaniak AI Produkt-ID. Sie finden sie in Ihrem Infomaniak Manager "
"unter AI Tools."

#: plugin.php:176 plugin.php:177
msgid "Infomaniak AI"
msgstr "Infomaniak AI"

#: src/Models/InfomaniakImageGenerationModel.php:42
#: src/Models/InfomaniakTextGenerationModel.php:42
#: src/Operations/InfomaniakOperationsHandler.php:177
msgid ""
"Infomaniak AI product ID is not configured. Set it via Settings > Infomaniak "
"AI, the INFOMANIAK_AI_PRODUCT_ID constant, or the infomaniak_ai_product_id "
"filter."
msgstr ""
"Die Infomaniak AI Produkt-ID ist nicht konfiguriert. Legen Sie sie unter "
"Einstellungen > Infomaniak AI, über die Konstante INFOMANIAK_AI_PRODUCT_ID "
"oder den Filter infomaniak_ai_product_id fest."

#. translators: %s: batch ID
#: src/Operations/InfomaniakOperationsHandler.php:82
#, php-format
msgid "Batch \"%s\" not found."
msgstr "Stapelverarbeitung „%s\" nicht gefunden."

#. translators: %s: batch ID
#: src/Operations/InfomaniakOperationsHandler.php:94
#, php-format
msgid "Batch \"%s\" returned an invalid response."
msgstr "Stapelverarbeitung „%s\" hat eine ungültige Antwort zurückgegeben."

#. translators: %s: batch ID
#: src/Operations/InfomaniakOperationsHandler.php:130
#, php-format
msgid "Batch \"%s\" not found or result not yet available."
msgstr ""
"Stapelverarbeitung „%s\" nicht gefunden oder Ergebnis noch nicht verfügbar."

#. translators: 1: batch ID, 2: HTTP status code
#: src/Operations/InfomaniakOperationsHandler.php:140
#, php-format
msgid "Failed to download batch \"%1$s\" result. HTTP status: %2$d."
msgstr ""
"Fehler beim Herunterladen des Ergebnisses der Stapelverarbeitung „%1$s\". "
"HTTP-Status: %2$d."

#. translators: %s: batch ID
#: src/Operations/InfomaniakOperationsHandler.php:153
#, php-format
msgid "Batch \"%s\" download returned empty content."
msgstr ""
"Der Download der Stapelverarbeitung „%s\" hat einen leeren Inhalt "
"zurückgegeben."

#: src/Presets/BasePreset.php:180
msgid "The generated text."
msgstr "Der generierte Text."

#: src/Presets/BasePreset.php:296
msgid "Conversation identifier. Auto-generated if omitted."
msgstr "Konversationskennung. Wird automatisch generiert, wenn nicht angegeben."

#: src/Presets/BasePreset.php:448
msgid "AI Client is not available."
msgstr "Der KI-Client ist nicht verfügbar."

#: src/Presets/BasePreset.php:476
msgid "Failed to render prompt template."
msgstr "Fehler beim Rendern der Prompt-Vorlage."

#. translators: %s: comma-separated list of capability names
#: src/Provider/InfomaniakProvider.php:128
#, php-format
msgid "Unsupported model capabilities: %s"
msgstr "Nicht unterstützte Modellfähigkeiten: %s"

#: src/Provider/InfomaniakProvider.php:151
msgid ""
"Text and image generation with open-source models. Supports async batch "
"operations."
msgstr ""
"Text- und Bildgenerierung mit Open-Source-Modellen. Unterstützt asynchrone "
"Stapelverarbeitungen."
