#, php-format
msgid "Unsupported model capabilities: %s"
msgstr "Capacités de modèle non prises en charge : %s"

#: src/Provider/InfomaniakProvider.php:151
msgid ""
"Text and image generation with open-source models. Supports async batch "
"operations."
msgstr ""
"Génération de texte et d'images avec des modèles open source. Prend en "
"charge les opérations asynchrones par lots."
