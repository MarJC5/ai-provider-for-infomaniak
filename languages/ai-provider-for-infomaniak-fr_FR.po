msgid "The generated text."
msgstr "Le texte généré."

#: src/Presets/BasePreset.php:296
msgid "Conversation identifier. Auto-generated if omitted."
msgstr "Identifiant de conversation. Généré automatiquement si omis."

#: src/Presets/BasePreset.php:448
msgid "AI Client is not available."
msgstr "Le client IA n'est pas disponible."

#: src/Presets/BasePreset.php:476
msgid "Failed to render prompt template."
msgstr "Échec du rendu du modèle de prompt."

#. translators: %s: comma-separated list of capability names
