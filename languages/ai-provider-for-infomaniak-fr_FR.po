#. Plugin Name of the plugin
#: plugin.php
msgid "AI Provider for Infomaniak"
msgstr "Fournisseur IA pour Infomaniak"

#. Plugin URI of the plugin
#: plugin.php
msgid "https://www.infomaniak.com/en/hosting/ai-tools"
msgstr "https://www.infomaniak.com/fr/hebergement/ai-services"

#. Description of the plugin
#: plugin.php
msgid ""
"AI Provider for Infomaniak for the WordPress AI Client. Provides access to "
"open-source models (Llama, Mistral, DeepSeek, Qwen) hosted in Switzerland."
msgstr ""
"Fournisseur IA pour Infomaniak pour le client IA WordPress. Fournit l'accès "
"à des modèles open source (Llama, Mistral, DeepSeek, Qwen) hébergés en "
"Suisse."

#. Author of the plugin
#: plugin.php
msgid "Custom"
msgstr "Custom"

#: plugin.php:120
msgid "Infomaniak AI Configuration"
msgstr "Configuration Infomaniak AI"

#: plugin.php:123
msgid ""
"Configure your Infomaniak AI product settings. Your API token is managed via "
"Settings > Connectors."
msgstr ""
"Configurez les paramètres de votre produit Infomaniak AI. Votre jeton API "
"est géré via Réglages > Connecteurs."

#: plugin.php:134
msgid "Product ID"
msgstr "ID du produit"

#: plugin.php:144
msgid "Currently set via the INFOMANIAK_AI_PRODUCT_ID constant."
msgstr "Actuellement défini via la constante INFOMANIAK_AI_PRODUCT_ID."

#: plugin.php:149
msgid "Currently set via the infomaniak_ai_product_id filter."
msgstr "Actuellement défini via le filtre infomaniak_ai_product_id."

#: plugin.php:154
msgid ""
"Your Infomaniak AI product ID. Find it in your Infomaniak manager at AI "
"Tools."
msgstr ""
"Votre ID de produit Infomaniak AI. Retrouvez-le dans votre manager "
"Infomaniak sous AI Tools."

#: plugin.php:176 plugin.php:177
msgid "Infomaniak AI"
msgstr "Infomaniak AI"

#: src/Models/InfomaniakImageGenerationModel.php:42
#: src/Models/InfomaniakTextGenerationModel.php:42
#: src/Operations/InfomaniakOperationsHandler.php:177
msgid ""
"Infomaniak AI product ID is not configured. Set it via Settings > Infomaniak "
"AI, the INFOMANIAK_AI_PRODUCT_ID constant, or the infomaniak_ai_product_id "
"filter."
msgstr ""
"L'ID de produit Infomaniak AI n'est pas configuré. Définissez-le via "
"Réglages > Infomaniak AI, la constante INFOMANIAK_AI_PRODUCT_ID ou le filtre "
"infomaniak_ai_product_id."

#. translators: %s: batch ID
#: src/Operations/InfomaniakOperationsHandler.php:82
#, php-format
msgid "Batch \"%s\" not found."
msgstr "Le lot « %s » est introuvable."

#. translators: %s: batch ID
#: src/Operations/InfomaniakOperationsHandler.php:94
#, php-format
msgid "Batch \"%s\" returned an invalid response."
msgstr "Le lot « %s » a retourné une réponse invalide."

#. translators: %s: batch ID
#: src/Operations/InfomaniakOperationsHandler.php:130
#, php-format
msgid "Batch \"%s\" not found or result not yet available."
msgstr ""
"Le lot « %s » est introuvable ou le résultat n'est pas encore disponible."

#. translators: 1: batch ID, 2: HTTP status code
#: src/Operations/InfomaniakOperationsHandler.php:140
#, php-format
msgid "Failed to download batch \"%1$s\" result. HTTP status: %2$d."
msgstr ""
"Échec du téléchargement du résultat du lot « %1$s ». Statut HTTP : %2$d."

#. translators: %s: batch ID
#: src/Operations/InfomaniakOperationsHandler.php:153
#, php-format
msgid "Batch \"%s\" download returned empty content."
msgstr "Le téléchargement du lot « %s » a retourné un contenu vide."

